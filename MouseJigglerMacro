' =============================================
' Mouse Jiggler Macro
' Press F5 to run, Esc to stop
' =============================================

#If VBA7 Then
    Private Declare PtrSafe Function SetCursorPos Lib "user32" (ByVal x As Long, ByVal y As Long) As Long
    Private Declare PtrSafe Function GetCursorPos Lib "user32" (lpPoint As POINTAPI) As Long
#Else
    Private Declare Function SetCursorPos Lib "user32" (ByVal x As Long, ByVal y As Long) As Long
    Private Declare Function GetCursorPos Lib "user32" (lpPoint As POINTAPI) As Long
#End If

Private Type POINTAPI
    x As Long
    y As Long
End Type

Sub StartJiggler()
    Dim pt As POINTAPI
    Dim i As Long
    Dim jiggleAmount As Long
    Dim intervalSeconds As Double
    
    jiggleAmount = 5        ' pixels to move each jiggle
    intervalSeconds = 30    ' seconds between jiggles
    
    Do
        ' Get current mouse position
        GetCursorPos pt
        
        ' Jiggle right then back
        SetCursorPos pt.x + jiggleAmount, pt.y
        Application.Wait Now + TimeSerial(0, 0, 1)
        SetCursorPos pt.x, pt.y
        
        ' Wait for next interval, checking for Esc key
        Dim startTime As Double
        startTime = Timer
        Do While Timer - startTime < intervalSeconds
            DoEvents
            If GetAsyncKeyState(27) <> 0 Then  ' 27 = Esc key
                MsgBox "Mouse Jiggler stopped.", vbInformation
                Exit Sub
            End If
        Loop
    Loop
End Sub
